  "keyFeatures": [
    "Multi-tenant SaaS with schema isolation",
    "Chilean SII electronic invoicing (DTE) compliance",
    "Point of Sale with cash session management",
    "Inventory tracking with Kardex movements",
    "Customer credit accounts and payment processing",
    "Sales returns and credit notes",
    "Product catalog with brands and price lists",
    "User management with role-based access control",
    "Purchase and supplier management",
    "Daily reports and sales statistics"
  ],
  "publicApiSurface": [
    "POST /saas/tenants - Register new tenant",
    "GET /saas/tenants - List all tenants",
    "POST /saas/tenants/{id}/users - Assign user to tenant",
    "POST /sales/ - Create sale",
    "POST /sales/return - Process return/refund",
    "GET /sales/payment-methods - List payment methods",
    "POST /products/ - Create product",
    "GET /products/ - List products",
    "POST /customers/ - Create customer",
    "GET /customers/ - List customers",
    "POST /inventory/movement - Record stock movement",
    "GET /inventory/kardex - Get stock movement history",
    "POST /cash/sessions - Open cash session",
    "POST /cash/sessions/{id}/close - Close cash session",
    "GET /reports/daily - Get daily sales report",
    "GET /stats/dashboard - Get dashboard statistics",
    "POST /auth/login - Authenticate user",
    "POST /users/ - Create user",
    "GET /users/ - List users",
    "POST /roles/ - Create role",
    "GET /folios/ - List available folios"
  ]
